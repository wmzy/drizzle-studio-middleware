{
  "name": "drizzle-studio-middleware",
  "version": "0.0.0",
  "description": "Mount Drizzle Studio as middleware in your Hono/Express app",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.4.3",
    "zod": "^3.24.0"
  },
  "peerDependencies": {
    "drizzle-orm": ">=0.30.0",
    "hono": ">=4.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@vitest/coverage-v8": "^4.1.0",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.11.5",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/wmzy/drizzle-studio-middleware"
  },
  "license": "MIT"
}
